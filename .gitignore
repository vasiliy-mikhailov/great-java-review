# secrets — never commit
.env
.env.*
!.env.example
*.token

# python envs (dirs AND the `venv` symlink -> ../venv)
/venv
venv/
venv-oh/
__pycache__/
*.pyc

# cloned target repos + crawl cache (huge, regenerable from config seed_repos)
data/

# full agent/judge traces + per-call logs (large; regenerable) — keep summaries, drop raw dumps
results/traces/
results/traces_sub/
results/traces_v2/

# gepa run artifacts + logs
results/runs/
*.log
*.out
