# Copy to .env (gitignored) and fill in. NEVER commit the real .env.
# GitHub auth comes from the `gh` CLI keyring (fetched via `gh auth token`),
# so no GitHub token is stored here.

# OpenAI-compatible API key for the Qwen vLLM endpoint.
QWEN_API_KEY=sk-...

# Private inference endpoint base URL (OpenAI-compatible /v1).
# Overrides config.yaml's placeholder base_url at import time.
QWEN_BASE_URL=https://your-inference-endpoint/v1
