# secrets — never commit
.env
.env.*
!.env.example
*.token

# python envs
venv/
venv-oh/
__pycache__/
*.pyc

# cloned target repos + crawl cache (huge, regenerable from config seed_repos)
data/

# full agent/judge traces (large; regenerable by re-running) — keep summaries, drop raw dumps
results/traces/

# gepa run artifacts + logs
results/runs/
*.log
*.out
